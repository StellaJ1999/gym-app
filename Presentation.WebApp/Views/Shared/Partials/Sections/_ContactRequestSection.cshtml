@model Presentation.Models.CustomerService.ContactForm

@{
    // Vi läser TempData en gång så vi kan visa ett “flash message” i UI efter POST.
    // TempData finns bara för nästa request och försvinner efter att den har lästs, så vid refresh syns inget längre.
    var statusMessage = TempData["Message"]?.ToString();
}

<section class="section__contact-form">
    <div class="container">
        <div class="contact-form-area">
            <img src="images/contact-us-image.png" alt="woman working out and lifting a bar">

            <form id="contact-form" method="post" asp-action="Index" asp-controller="Support" novalidate>
                <div data-type="title" class="title">
                    <h2>Contact Us Today</h2>
                    <p>Ready to begin your fitness journey? Contact CoreFitnesss today and let our expert trainers guide you with the right program and support.</p>
                </div>

                <div data-type="firstname" class="form-group">
                    <label class="form-label" asp-for="FirstName"></label>
                    <input class="form-input" asp-for="FirstName" />
                    <span class="form-field-validation" asp-validation-for="FirstName"></span>
                </div>
                <div data-type="lastname" class="form-group">
                    <label class="form-label" asp-for="LastName"></label>
                    <input class="form-input" asp-for="LastName" />
                    <span class="form-field-validation" asp-validation-for="LastName"></span>
                </div>
                <div data-type="email" class="form-group">
                    <label class="form-label" asp-for="Email"></label>
                    <input class="form-input" asp-for="Email" />
                    <span class="form-field-validation" asp-validation-for="Email"></span>
                </div>
                <div data-type="phone" class="form-group">
                    <label class="form-label" asp-for="Phone"></label>
                    <input class="form-input" asp-for="Phone" />
                    <span class="form-field-validation" asp-validation-for="Phone"></span>
                </div>
                <div data-type="message" class="form-group">
                    <label class="form-label" asp-for="Message"></label>
                    <textarea class="form-input" asp-for="Message"></textarea>
                    <span class="form-field-validation" asp-validation-for="Message"></span>
                </div>
                <div data-type="submit" class="form-group">
                    <button class="btn" type="submit">Submit Message</button>

                    @if (!string.IsNullOrWhiteSpace(statusMessage))
                    {
                        <span class="contact-form-status" aria-live="polite">@statusMessage</span>
                    }
                </div>
            </form>
        </div>
    </div>
</section>